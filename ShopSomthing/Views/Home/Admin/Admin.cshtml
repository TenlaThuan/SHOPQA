@{
    ViewData["Title"] = "Admin";
}
<link href="~/css/admin.css" rel="stylesheet" />
<div class="container dashboard-container">
    <h2 class="mb-4">Bảng quản lý</h2>

    <h4>Quản lý sản phẩm</h4>
    <table class="table table-bordered">
        <thead>
            <tr>
                <th>Ảnh</th>
                <th>Tên</th>
                <th>Site</th>
                <th>Thương hiệu</th>
                <th>Chất liệu</th>
                <th>Xuất xứ</th>
                <th>Giá</th>
                <th>Công cụ</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td><img src="~/img/aonam.png" alt="Product"></td>
                <td>Áo thun trắng</td>
                <td>M</td>
                <td>Something</td>
                <td>Cotton</td>
                <td>VIET NAM</td>
                <td>$120.00</td>
                <td>
                    <button class="btn btn-warning btn-sm">Sửa</button>
                    <button class="btn btn-danger btn-sm">Xóa</button>
                </td>
            </tr>
        </tbody>
    </table>
    <button class="btn btn-success">Thêm sản phẩm</button>

    <hr>

    <h4>Quản lý tài khoản</h4>
    <table class="table table-bordered">
        <thead>
            <tr>
                <th>Tên</th>
                <th>Email</th>
                <th>Quyền</th>
                <th>Công cụ</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td>john_doe</td>
                <td>john@example.com</td>
                <td>Admin</td>
                <td>
                    <button class="btn btn-warning btn-sm">Sửa</button>
                    <button class="btn btn-danger btn-sm">Xóa</button>
                </td>
            </tr>
        </tbody>
    </table>
    <button class="btn btn-success">Thêm người dùng</button>

    <hr>

    <h4>Thông kê</h4>
    <div class="row text-center">
        <div class="col-md-4">
            <div class="p-3 bg-primary text-white rounded">Total Products: 50</div>
        </div>
        <div class="col-md-4">
            <div class="p-3 bg-success text-white rounded">Total Users: 200</div>
        </div>
        <div class="col-md-4">
            <div class="p-3 bg-danger text-white rounded">Total Orders: 150</div>
        </div>
    </div>
</div>